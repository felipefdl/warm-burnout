    <option name="CARET_COLOR" value="{{ cursor.hex }}"/>
    <option name="CARET_ROW_COLOR" value="{{ caret_row_bg.hex }}"/>
    <option name="GUTTER_BACKGROUND" value="{{ background.hex }}"/>
    <option name="LINE_NUMBERS_COLOR" value="{{ muted.hex }}"/>
